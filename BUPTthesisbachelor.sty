% Appendix helper
\newcounter{appendixno}
\newcommand{\buptappendix}[1]{%
    \refstepcounter{appendixno}%
    \setcounter{figure}{0}%
    \setcounter{table}{0}%
    \setcounter{equation}{0}%
    \setcounter{lstlisting}{0}%
    \renewcommand{\thefigure}{附\arabic{appendixno}-\arabic{figure}}%
    \renewcommand{\thetable}{附\arabic{appendixno}-\arabic{table}}%
    \renewcommand{\theequation}{附\arabic{appendixno}-\arabic{equation}}%
    \renewcommand{\thelstlisting}{附\arabic{appendixno}-\arabic{lstlisting}}%
    \chapter*{附录\arabic{appendixno}\quad #1}%
    \phantomsection%
    \addcontentsline{toc}{chapter}{附录\arabic{appendixno}\quad #1}%
}

