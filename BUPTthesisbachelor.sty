% Figure helper
\newcommand{\buptfigure}[4][width=0.7\textwidth]{%
    \begin{figure}[!htbp]%
        \centering
        \includegraphics[#1]{#2}%
        \caption{#3}%
        \label{#4}%
    \end{figure}%
}

% Table helpers
\newenvironment{bupttable}[2]{%
    \begin{table}[!htbp]%
        \centering%
        \renewcommand{\arraystretch}{1.25}%
        \setlength{\abovecaptionskip}{0.5\baselineskip}%
        \setlength{\belowcaptionskip}{0.5\baselineskip}%
        \caption{#1}%
        \label{#2}%
}{%
    \end{table}%
}

\newenvironment{buptlongtable}[3]{%
    \renewcommand{\arraystretch}{1.25}%
    \setlength{\abovecaptionskip}{0.5\baselineskip}%
    \setlength{\belowcaptionskip}{0.5\baselineskip}%
    \begin{longtable}{#1}
        \caption{#2}
        \label{#3} \\
}{%
    \end{longtable}%
}

% Algorithm environment in three-line-table style
\newenvironment{buptalgorithm}[2]{%
    \begin{table}[!htbp]
        \centering
        \setlength{\abovecaptionskip}{0.5\baselineskip}
        \setlength{\belowcaptionskip}{0.5\baselineskip}
        \caption{#1}
        \label{#2}
        \begin{tabular}{@{}p{\textwidth}@{}}
            \toprule
            \begin{minipage}{\linewidth}
                \wuhao\setstretch{1.2}\selectfont
                \renewcommand{\algorithmicrequire}{\textbf{输入：}}
                \renewcommand{\algorithmicensure}{\textbf{输出：}}
                \begin{algorithmic}[1]
}{%
                \end{algorithmic}
            \end{minipage}\\
            \bottomrule
        \end{tabular}
    \end{table}
}

