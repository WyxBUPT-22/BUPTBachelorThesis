% Footnote
\newcommand{\buptcirclednumber}[1]{%
    \ifcase#1\or ①\or ②\or ③\or ④\or ⑤\or ⑥\or ⑦\or ⑧\or ⑨\or ⑩\or
    ⑪\or ⑫\or ⑬\or ⑭\or ⑮\or ⑯\or ⑰\or ⑱\or ⑲\or ⑳%
    \else \textcircled{\scriptsize #1}%
    \fi
}
\renewcommand{\thefootnote}{\buptcirclednumber{\value{footnote}}}
\setlength{\footnotesep}{12pt}
